# Server the mobile app talks to. Must be reachable from the device/emulator.
# Production (deployed):
EXPO_PUBLIC_API_URL=https://nex-attender.vercel.app

# For local backend testing instead, comment the line above and use your
# machine's LAN IP (NOT localhost — the phone can't reach the PC's localhost):
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
